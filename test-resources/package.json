{
  "name": "one-login-test-resources",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build:env": "./generate_env_file.sh",
    "build:infra": "./combine_template.sh",
    "format": "prettier --write '**/*.{ts,md}'",
    "format:check": "prettier --check '**/*.{ts,md}'",
    "lint": "eslint ./src/functions",
    "test:api": "vitest run tests/api-tests/ --coverage.enabled=false --outputFile.junit=results/api-tests.xml",
    "test:infra": "vitest run tests/infrastructure-tests/ --coverage.enabled=false --outputFile.junit=results/infra-tests.xml",
    "test:unit": "vitest run src/functions/ --outputFile.junit=results/unit-tests.xml",
    "test:unit:watch": "vitest watch src/functions/ --outputFile.junit=results/unit-tests.xml"
  },
  "engines": {
    "node": "22"
  },
  "devDependencies": {
    "@aws-sdk/client-secrets-manager": "3.1080.0",
    "@aws-sdk/credential-providers": "3.1080.0",
    "@eslint/js": "10.0.1",
    "@types/aws-lambda": "8.10.162",
    "@types/js-yaml": "4.0.9",
    "@types/node": "22.20.0",
    "@vitest/coverage-v8": "4.1.10",
    "aws-cdk-lib": "2.261.0",
    "aws-sdk-client-mock": "4.1.0",
    "aws-sdk-client-mock-vitest": "7.1.0",
    "aws4-axios": "3.4.0",
    "axios": "1.18.1",
    "axios-retry": "4.5.0",
    "brace-expansion": ">=5.0.7",
    "dotenv": "17.4.2",
    "eslint": "10.6.0",
    "js-yaml": "4.2.0",
    "prettier": "3.9.4",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10",
    "yaml-cfn": "0.3.2"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "2.33.1",
    "@aws-sdk/client-dynamodb": "3.1080.0",
    "@aws-sdk/client-s3": "3.1080.0",
    "@aws-sdk/util-dynamodb": "3.996.5",
    "@smithy/node-http-handler": "4.9.3",
    "esbuild": "0.28.1",
    "jose": "5.10.0"
  },
  "overrides": {
    "micromatch": "4.0.8"
  }
}
