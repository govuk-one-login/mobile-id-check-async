{
  "name": "one-login-async-credentials",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "deploy:dev": "cd ../helper-scripts && ./deploy_backend.sh",
    "build:infra": "./combine_template.sh",
    "generate-proxy-open-api": "node ./generate-proxy-private-openapi.js",
    "format": "./node_modules/.bin/prettier --write '**/*.{ts,md}'",
    "format:check": "./node_modules/.bin/prettier --check '**/*.{ts,md}'",
    "lint": "./node_modules/.bin/eslint ./src/functions",
    "test": "vitest run --exclude **/api-tests",
    "test:api": "VITEST_JUNIT_FILE=api-report.xml vitest run api-tests --coverage.enabled=false",
    "test:infra": "VITEST_JUNIT_FILE=infra-report.xml vitest run infra-tests --coverage.enabled=false",
    "test:pact": "VITEST_JUNIT_FILE=pact-report.xml vitest run src/functions/tests/pact/ --coverage.enabled=false",
    "test:pact:authorize": "bash -c 'curl -sS -o /dev/null --fail -u $PACT_BROKER_USERNAME:$PACT_BROKER_PASSWORD \"$PACT_BROKER_URL?testSource=$PACT_BROKER_SOURCE_SECRET\"'",
    "test:pact:ci": "npm run test:pact:authorize && npm run test:pact",
    "test:pact:local": ". ./src/functions/tests/pact/setPactCredentials/set_pact_credentials.sh && npm run test:pact",
    "test:unit": "VITEST_JUNIT_FILE=unit-report.xml vitest run  --exclude **/pact --exclude **/api-tests --exclude **/infra-tests"
  },
  "engines": {
    "node": "22"
  },
  "devDependencies": {
    "@aws-sdk/credential-providers": "3.1025.0",
    "@eslint/js": "10.0.1",
    "@pact-foundation/pact": "16.3.0",
    "@types/aws-lambda": "8.10.161",
    "@types/express": "5.0.6",
    "@types/js-yaml": "4.0.9",
    "@types/node": "22.19.17",
    "@vitest/coverage-v8": "4.1.2",
    "aws-cdk-lib": "2.248.0",
    "aws-sdk-client-mock": "4.1.0",
    "aws-sdk-client-mock-vitest": "7.0.1",
    "aws4-axios": "3.4.0",
    "axios-retry": "4.5.0",
    "dotenv": "17.4.1",
    "eslint": "10.2.0",
    "express": "5.2.1",
    "js-yaml": "4.1.1",
    "prettier": "3.8.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.0",
    "vitest": "4.1.2",
    "yaml": "2.8.3",
    "yaml-cfn": "0.3.2"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "2.32.0",
    "@aws-lambda-powertools/parameters": "2.32.0",
    "@aws-sdk/client-dynamodb": "3.1025.0",
    "@aws-sdk/client-kms": "3.1025.0",
    "@aws-sdk/client-s3": "3.1025.0",
    "@aws-sdk/client-secrets-manager": "3.1025.0",
    "@aws-sdk/client-sqs": "3.1025.0",
    "@aws-sdk/client-ssm": "3.1025.0",
    "@aws-sdk/node-http-handler": "3.374.0",
    "@aws-sdk/util-dynamodb": "3.996.2",
    "@govuk-one-login/mobile-id-check-biometric-credential": "3.1.10",
    "axios": "1.15.0",
    "ecdsa-sig-formatter": "1.0.11",
    "esbuild": "0.28.0",
    "jose": "5.10.0"
  },
  "overrides": {
    "flatted": ">3.4.0",
    "micromatch": "4.0.8"
  }
}
